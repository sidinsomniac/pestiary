# DeepSeek API (replaces Anthropic for LLM evaluation)
# Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Google Sheets integration (live Google Form → Sheet flow)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Keep the literal \n escapes in the key; the code converts them to newlines.
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_ID=

# Optional: point the frontend at a CDN-hosted triage_result.json instead of the local file
NEXT_PUBLIC_RESULTS_URL=
